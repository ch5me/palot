{
	"name": "@ch5me/elf-desktop",
	"version": "0.11.0",
	"description": "AI-powered coding assistant desktop app",
	"author": "Elf",
	"license": "MIT",
	"homepage": "https://github.com/ItsWendell/elf",
	"repository": {
		"type": "git",
		"url": "https://github.com/ItsWendell/elfgit",
		"directory": "apps/desktop"
	},
	"private": true,
	"type": "module",
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "cd ../.. && bunx devmux ensure desktop",
		"dev:wayland": "cd ../.. && bunx devmux ensure desktop-wayland",
		"dev:web": "node ../../node_modules/vite/bin/vite.js --config src/renderer/vite.web.config.ts --port $PORT",
		"dev:electron-local": "node ../../node_modules/electron-vite/bin/electron-vite.js dev",
		"dev:electron-wayland-local": "node ../../node_modules/electron-vite/bin/electron-vite.js dev -- --ozone-platform=wayland --enable-features=WaylandWindowDecorations --disable-features=WaylandFractionalScaleV1",
		"build": "bun ../../scripts/build-plugins.ts && node ../../node_modules/electron-vite/bin/electron-vite.js build",
		"build:plugins": "bun ../../scripts/build-plugins.ts",
		"preview": "node ../../node_modules/electron-vite/bin/electron-vite.js preview",
		"package": "bun run build && electron-builder --config electron-builder.yml --publish never",
		"package:linux": "bun run build && electron-builder --linux --config electron-builder.yml --publish never",
		"package:mac": "bun run build && electron-builder --mac --config electron-builder.yml --publish never",
		"package:mac:arm64": "bun run build && electron-builder --mac --arm64 --config electron-builder.yml --publish never",
		"package:mac:x64": "bun run build && electron-builder --mac --x64 --config electron-builder.yml --publish never",
		"package:win": "bun run build && electron-builder --win --config electron-builder.yml --publish never",
		"package:all": "bun run build && electron-builder --linux --mac --win --config electron-builder.yml --publish never",
		"eb:linux": "electron-builder --linux --config electron-builder.yml --publish never",
		"eb:mac": "electron-builder --mac --config electron-builder.yml --publish never",
		"eb:win": "electron-builder --win --config electron-builder.yml --publish never",
		"rebuild": "electron-rebuild",
		"lint": "bun ../../scripts/validate-plugin-manifests.ts && biome check .",
		"check-types": "bunx tsgo --noEmit",
		"clean": "rm -rf out release dist node_modules .turbo"
	},
	"dependencies": {
		"@ch5me/agent-runtime-contracts": "file:../../../ch5-packages/packages/contracts/agent-runtime-contracts",
		"@ch5me/dag-sparkline": "^0.1.0",
		"@ch5me/elf-configconv": "workspace:*",
		"@ch5me/elf-ui": "workspace:*",
		"@ch5me/firefly-design": "^0.1.3",
		"@ch5me/react-dev-surface": "^0.1.0",
		"@ch5me/workspace": "^0.1.5",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@libsql/client": "^0.17.0",
		"@opencode-ai/sdk": "^1.2.1",
		"@pierre/diffs": "^1.0.10",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.1",
		"@tanstack/react-query": "^5.90.20",
		"@tanstack/react-router": "^1.158.4",
		"@tanstack/react-virtual": "^3.13.0",
		"bonjour-service": "^1.3.0",
		"dockview-react": "^6.6.1",
		"drizzle-orm": "^1.0.0-beta.15-859cf75",
		"electron-updater": "^6.7.3",
		"fuzzysort": "^3.1.0",
		"hono": "4.11.9",
		"jotai": "^2.17.1",
		"jotai-family": "^1.0.1",
		"lucide-react": "^0.564.0",
		"monaco-editor": "^0.55.1",
		"motion": "^12.34.0",
		"node-pty": "^1.1.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-markdown": "^10.1.0",
		"react-resizable-panels": "^4.6.2",
		"react-syntax-highlighter": "^16.1.0",
		"remark-gfm": "^4.0.1",
		"rich-textarea": "^0.27.0",
		"rrule": "^2.8.1",
		"semver": "^7.7.4",
		"simple-git": "^3.30.0",
		"sonner": "^2.0.7",
		"three": "^0.184.0",
		"vscode-oniguruma": "^2.0.1",
		"vscode-textmate": "^9.3.2",
		"zod": "^4.1.11"
	},
	"optionalDependencies": {
		"electron-liquid-glass": "^1.1.1"
	},
	"devDependencies": {
		"@ch5me/effects": "^0.7.1",
		"@ch5me/elf-server": "workspace:*",
		"@electron/rebuild": "^4.0.3",
		"@tailwindcss/vite": "^4.0.0",
		"@types/node": "^24.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/react-syntax-highlighter": "^15.5.13",
		"@types/semver": "^7.7.1",
		"@types/three": "^0.184.1",
		"@typescript/native-preview": "^7.0.0-dev.20260207.1",
		"@vitejs/plugin-react": "^5.1.4",
		"drizzle-kit": "^1.0.0-beta.15-859cf75",
		"electron": "40.2.1",
		"electron-builder": "^26.0.0",
		"electron-vite": "^5.0.0",
		"shiki": "^3.22.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.7.0",
		"vite": "^7.3.1",
		"vite-plugin-static-copy": "^3.2.0"
	}
}
