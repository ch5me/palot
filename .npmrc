# @ch5me + @chriscode packages install from the HQ Verdaccio registry (off-GitHub policy).
# skill ch5me-npm-packages. Never commit a literal token. Backup: .npmrc.github.bak
# @chriscode is HQ-published too (e.g. devmux); public npm has stale/buggy copies.
@ch5me:registry=https://npm.ch5.me/
@chriscode:registry=https://npm.ch5.me/
//npm.ch5.me/:_authToken=${NPM_TOKEN}
