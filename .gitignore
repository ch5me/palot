# Dependencies
node_modules/

# Build outputs
dist/
.next/
out/

# Turborepo

# Tauri
src-tauri/target/

# Electron Builder
release/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Research (local only)
research/

# Private docs and notes (local only)
.private/

# Local agent instructions (private per-developer)
AGENTS.local.md

# Git worktrees
.worktrees/

# Local working directory
.local/

# Storybook build output
storybook-static/

# Root .turbo: track config, ignore cache
.turbo/*
!.turbo/config.json
# Nested package .turbo dirs (all cache, nothing tracked)
apps/**/.turbo/
packages/**/.turbo/

# Transient agent isolation worktrees (harness-created; a stray nested biome.json
# in one breaks `biome check .`). Never tracked; ignored so tooling skips them.
.claude/worktrees/

# Lavish HTML review artifacts (generated by the `lavish` skill; local only).
.lavish/

# Python bytecode cache (scripts/*.py compiled by the verify helpers).
__pycache__/
*.pyc

# Scratch session handoff docs (operator notes; never durable repo source).
handoff-*.md

# Stale npmrc backups from the GitHub→HQ registry flip (external leftover).
.npmrc.github.bak
