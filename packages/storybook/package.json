{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "@ch5me/elf-storybook",
	"private": true,
	"type": "module",
	"scripts": {
		"storybook": "../../node_modules/.bin/storybook dev -p ${PORT:-6006} --exact-port --disable-telemetry --no-open",
		"dev": "../../node_modules/.bin/storybook dev -p ${PORT:-6006} --exact-port --disable-telemetry --no-open",
		"build": "../../node_modules/.bin/storybook build --disable-telemetry",
		"check-types": "tsc --noEmit -p tsconfig.json"
	},
	"devDependencies": {
		"@ch5me/elf-ui": "workspace:*",
		"@storybook/addon-a11y": "^10.4.4",
		"@storybook/addon-docs": "^10.4.4",
		"@storybook/addon-links": "^10.4.4",
		"@storybook/react-vite": "^10.4.4",
		"@tailwindcss/vite": "^4.1.14",
		"@types/node": "^24.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"storybook": "^10.4.4",
		"typescript": "^5.7.0",
		"vite": "^7.3.1"
	}
}
