#!/usr/bin/env bun
import { mkdirSync, writeFileSync } from "node:fs"
import path from "node:path"
import { existsSync, readFileSync } from "node:fs"
import { getBrowserLaneDataDir } from "../../apps/desktop/src/main/automation/paths"
import {
	encodeBrowserLaneAuth,
	parseBrowserLaneArgs,
	readBrowserLaneAuthFromEnv,
	runRemoteCommand,
} from "./lib"

function getLaneEndpoints(laneId: string) {
	const envFile = path.join(getBrowserLaneDataDir(), laneId, ".env")
	if (!existsSync(envFile)) {
		throw new Error(`Missing runtime env for lane ${laneId}`)
	}
	const env = Object.fromEntries(
		readFileSync(envFile, "utf-8")
			.split("\n")
			.filter(Boolean)
			.map((line) => {
				const [key, ...rest] = line.split("=")
				return [key, rest.join("=")]
			}),
	)
	return {
		streamBackendUrl: `http://127.0.0.1:${env.STREAM_PORT}`,
		hostPublishedCdpEndpoint: `http://127.0.0.1:${env.CDP_PORT}`,
		relayCdpEndpoint: env.CDP_CONTAINER_ENDPOINT || `http://127.0.0.1:${env.CDP_PORT}`,
		internalCdpEndpoint:
			(env.CDP_CONTAINER_ENDPOINT || `http://127.0.0.1:${env.CDP_PORT}`) === `http://127.0.0.1:${env.CDP_PORT}`
				? "http://127.0.0.1:9222"
				: (env.CDP_CONTAINER_ENDPOINT || `http://127.0.0.1:${env.CDP_PORT}`).replace(/:\d+$/, ':9222'),
		auth: readBrowserLaneAuthFromEnv(env),
	}
}

const args = parseBrowserLaneArgs(process.argv.slice(2))
const laneId = args.lane
const output = path.join(
	process.cwd(),
	".sisyphus",
	"evidence",
	"browser-lanes",
	"task-11-cdp.txt",
)
mkdirSync(path.dirname(output), { recursive: true })

if (args.mode === "remote") {
	const cdpUrl = args.cdpEndpoint || "http://127.0.0.1:9222"
	const auth =
		args.streamUser && args.streamPassword
			? encodeBrowserLaneAuth({ user: args.streamUser, password: args.streamPassword })
			: undefined
	if (args.ssh) {
		const result = await runRemoteCommand(
			args.ssh,
			auth
				? `curl -sf -u ${JSON.stringify(args.streamUser)}:${JSON.stringify(args.streamPassword)} ${JSON.stringify(`${cdpUrl}/json/version`)}`
				: `curl -sf ${JSON.stringify(`${cdpUrl}/json/version`)}`,
		)
		writeFileSync(
			output,
			JSON.stringify(
				{ mode: "remote", laneId, ssh: args.ssh, cdpUrl, ok: result.code === 0, stdout: result.stdout, stderr: result.stderr },
				null,
				2,
			),
			"utf-8",
		)
		process.exit(result.code)
	}
	try {
		const response = await fetch(`${cdpUrl}/json/version`, {
			signal: AbortSignal.timeout(5000),
			headers: auth ? { authorization: auth } : undefined,
		})
		const body = await response.text()
		writeFileSync(
			output,
			JSON.stringify({ mode: "remote", laneId, cdpUrl: `${cdpUrl}/json/version`, status: response.status, body }, null, 2),
			"utf-8",
		)
		process.exit(response.ok ? 0 : 1)
	} catch (error) {
		writeFileSync(
			output,
			JSON.stringify({ mode: "remote", laneId, cdpUrl, error: error instanceof Error ? error.message : String(error) }, null, 2),
			"utf-8",
		)
		process.exit(1)
	}
}

try {
	const { hostPublishedCdpEndpoint, relayCdpEndpoint, internalCdpEndpoint, auth } = getLaneEndpoints(laneId)
	const authHeader = auth ? encodeBrowserLaneAuth(auth) : undefined
	const [hostPublishedResponse, relayResponse, internalResponse] = await Promise.all([
		fetch(`${hostPublishedCdpEndpoint}/json/version`, {
			signal: AbortSignal.timeout(5000),
			headers: authHeader ? { authorization: authHeader } : undefined,
		}),
		fetch(`${relayCdpEndpoint}/json/version`, {
			signal: AbortSignal.timeout(5000),
			headers: authHeader ? { authorization: authHeader } : undefined,
		}),
		fetch(`${cdpInternalEndpoint}/json/version`, {
			signal: AbortSignal.timeout(5000),
			headers: authHeader ? { authorization: authHeader } : undefined,
		}),
	])
	const [hostPublishedBody, relayBody, internalBody] = await Promise.all([
		hostPublishedResponse.text(),
		relayResponse.text(),
		internalResponse.text(),
	])
	writeFileSync(
		output,
		JSON.stringify(
			{
				mode: "local",
				laneId,
				hostPublishedUrl: `${hostPublishedCdpEndpoint}/json/version`,
				hostPublishedStatus: hostPublishedResponse.status,
				hostPublishedBody,
				relayUrl: `${relayCdpEndpoint}/json/version`,
				relayStatus: relayResponse.status,
				relayBody,
				internalUrl: `${internalCdpEndpoint}/json/version`,
				internalStatus: internalResponse.status,
				internalBody,
				naming: {
					hostPublished: "Host port exposed to Palot and external clients.",
					relay: "Managed listener that forwards host traffic into Chromium loopback.",
					internal: "Chromium-owned loopback endpoint inside the container namespace.",
				},
			},
			null,
			2,
		),
		"utf-8",
	)
	process.exit(hostPublishedResponse.ok && relayResponse.ok && internalResponse.ok ? 0 : 1)
} catch (error) {
	writeFileSync(
		output,
		JSON.stringify({ mode: "local", laneId, error: error instanceof Error ? error.message : String(error) }, null, 2),
		"utf-8",
	)
	process.exit(1)
}
