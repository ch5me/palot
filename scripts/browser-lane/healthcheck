#!/usr/bin/env bun
import { existsSync, readFileSync } from "node:fs"
import path from "node:path"
import { getBrowserLaneDataDir } from "../../apps/desktop/src/main/automation/paths"
import {
	encodeBrowserLaneAuth,
	parseBrowserLaneArgs,
	readBrowserLaneAuthFromEnv,
	runCommand,
	runRemoteCommand,
} from "./lib"

async function check(url: string, pathSuffix = "", authHeader?: string) {
	try {
		const headers: Record<string, string> = {}
		if (authHeader) headers.authorization = authHeader
		const response = await fetch(`${url}${pathSuffix}`, {
			signal: AbortSignal.timeout(3000),
			headers,
		})
		return {
			ok: response.ok,
			status: response.status,
		}
	} catch (error) {
		return {
			ok: false,
			status: 0,
			error: error instanceof Error ? error.message : String(error),
		}
	}
}

function parseEnv(envFile: string) {
	return Object.fromEntries(
		readFileSync(envFile, "utf-8")
			.split("\n")
			.filter(Boolean)
			.map((line) => {
				const [key, ...rest] = line.split("=")
				return [key, rest.join("=")]
			}),
	)
}

const args = parseBrowserLaneArgs(process.argv.slice(2))
const laneId = args.lane

if (args.mode === "remote") {
		const streamTarget = args.streamBackendUrl || "http://127.0.0.1:3000"
		const cdpTarget = args.cdpEndpoint || "http://127.0.0.1:9222"
		const auth =
			args.streamUser && args.streamPassword
				? encodeBrowserLaneAuth({ user: args.streamUser, password: args.streamPassword })
				: undefined
		if (args.ssh) {
			const streamProbe = await runRemoteCommand(
				args.ssh,
				auth
					? `curl -sf -u ${JSON.stringify(args.streamUser)}:${JSON.stringify(args.streamPassword)} ${JSON.stringify(streamTarget)} >/dev/null`
					: `curl -sf ${JSON.stringify(streamTarget)} >/dev/null`,
			)
			const cdpProbe = await runRemoteCommand(
				args.ssh,
				auth
					? `curl -sf -u ${JSON.stringify(args.streamUser)}:${JSON.stringify(args.streamPassword)} ${JSON.stringify(`${cdpTarget}/json/version`)}`
					: `curl -sf ${JSON.stringify(`${cdpTarget}/json/version`)}`,
			)
			const streamOk = streamProbe.code === 0
			const cdpOk = cdpProbe.code === 0
			console.log(JSON.stringify({
				action: "healthcheck",
				mode: "remote",
				laneId,
				ssh: args.ssh,
				streamBackendUrl: streamTarget,
				streamPath: `/browser/${laneId}/`,
				cdpEndpoint: cdpTarget,
				stream: { ok: streamOk, status: streamOk ? 200 : 0, error: streamOk ? undefined : streamProbe.stderr.trim() || streamProbe.stdout.trim() },
				cdp: { ok: cdpOk, status: cdpOk ? 200 : 0, error: cdpOk ? undefined : cdpProbe.stderr.trim() || cdpProbe.stdout.trim() },
			}, null, 2))
			process.exit(streamOk || cdpOk ? 0 : 1)
		}
		const [stream, cdp] = await Promise.all([
			check(streamTarget, "", auth),
			check(cdpTarget, "/json/version", auth),
		])
		console.log(JSON.stringify({
			action: "healthcheck",
			mode: "remote",
			laneId,
			streamBackendUrl: streamTarget,
			streamPath: `/browser/${laneId}/`,
			cdpEndpoint: cdpTarget,
			stream,
			cdp,
		}, null, 2))
		process.exit(stream.ok || cdp.ok ? 0 : 1)
}

const envFile = path.join(getBrowserLaneDataDir(), laneId, ".env")
if (!existsSync(envFile)) {
	console.error(`Missing runtime env for lane ${laneId}`)
	process.exit(1)
}
const env = parseEnv(envFile)
const streamBackendUrl = `http://127.0.0.1:${env.STREAM_PORT}`
const hostPublishedCdpEndpoint = `http://127.0.0.1:${env.CDP_PORT}`
const relayCdpEndpoint = env.CDP_CONTAINER_ENDPOINT || `http://127.0.0.1:${env.CDP_PORT}`
const internalCdpEndpoint = env.CDP_INTERNAL_ENDPOINT || "http://127.0.0.1:9222"
const localAuth = readBrowserLaneAuthFromEnv(env)
const authHeader = localAuth ? encodeBrowserLaneAuth(localAuth) : undefined
const [stream, hostPublishedCdp] = await Promise.all([
	check(streamBackendUrl, "", authHeader),
	check(hostPublishedCdpEndpoint, "/json/version", authHeader),
])
const details: Record<string, unknown> = {
	action: "healthcheck",
	mode: "local",
	laneId,
	streamBackendUrl,
	streamPath: `/browser/${laneId}/`,
	hostPublishedCdpEndpoint,
	hostPublishedCdp,
	relayCdp: {
		url: relayCdpEndpoint,
		ok: relayCdpEndpoint === hostPublishedCdpEndpoint ? hostPublishedCdp.ok : null,
		status: relayCdpEndpoint === hostPublishedCdpEndpoint ? hostPublishedCdp.status : null,
		note: relayCdpEndpoint === hostPublishedCdpEndpoint ? "Host-published port terminates at the relay listener" : "Relay endpoint is container-only from this host context",
	},
	internalCdp: {
		url: internalCdpEndpoint,
		note: "Chromium binds this loopback endpoint inside the container namespace only; verify with docker exec or cdp-smoke.",
	},
	stream,
}
if (args.verbose) {
	const inspectResult = await runCommand(
		"docker",
		["ps", "-q", "--filter", `name=browser-lane-${laneId}`],
		{ capture: true },
	)
	const containerId = inspectResult.stdout.trim()
	const internalProbe = containerId
		? await runCommand(
			"docker",
			["exec", containerId, "sh", "-lc", `curl -sf ${JSON.stringify(`${internalCdpEndpoint}/json/version`)}`],
			{ capture: true },
		)
		: { code: 1, stdout: "", stderr: `No running managed container found for lane ${laneId}` }
	details.internalCdp = {
		url: internalCdpEndpoint,
		ok: internalProbe.code === 0,
		status: internalProbe.code === 0 ? 200 : 0,
		stdout: internalProbe.stdout.trim() || undefined,
		error: internalProbe.code === 0 ? undefined : internalProbe.stderr.trim() || internalProbe.stdout.trim() || undefined,
		note: "Verified via docker exec inside the managed container namespace.",
	}
}
console.log(JSON.stringify(details, null, 2))
const internalOk =
	!args.verbose ||
	(typeof details.internalCdp === "object" && details.internalCdp !== null && "ok" in details.internalCdp
		? Boolean((details.internalCdp as { ok?: boolean }).ok)
		: false)
process.exit(stream.ok || (hostPublishedCdp.ok && internalOk) ? 0 : 1)
