{
	"version": 1,
	"project": "elf",
	"proxy": {
		"enabled": true,
		"hostnamePattern": "{service}.{project}.localhost"
	},
	"defaults": {
		"startupTimeoutSeconds": 120
	},
	"services": {
		"server": {
			"cwd": "apps/server",
			"command": "bun run dev",
			"health": { "type": "port", "port": 30206 },
			"dependsOn": [],
			"proxy": true,
			"env": {
				"PORT": "30206",
				"OPENCODE_PORT": "4096",
				"OPENCODE_HOSTNAME": "127.0.0.1",
				"OPENCODE_MODE": "external"
			}
		},
		"web": {
			"cwd": "apps/desktop",
			"command": "bun run dev:web",
			"health": { "type": "port", "port": 20883 },
			"dependsOn": ["server"],
			"proxy": true,
			"env": {
				"PORT": "20883"
			}
		},
		"storybook": {
			"cwd": ".",
			"command": "bun run storybook",
			"health": { "type": "port", "port": 6006 },
			"proxy": true
		},
		"desktop": {
			"cwd": "apps/desktop",
			"command": "bun run dev:electron-local",
			"health": { "type": "port", "port": 1420 },
			"dependsOn": [],
			"env": {
				"OPENCODE_PORT": "4096"
			}
		},
		"desktop-wayland": {
			"cwd": "apps/desktop",
			"command": "bun run dev:electron-wayland-local",
			"health": { "type": "port", "port": 1420 },
			"dependsOn": [],
			"env": {
				"OPENCODE_PORT": "4096"
			}
		}
	}
}
