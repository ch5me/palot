{
	"version": 1,
	"project": "elf",
	"services": {
		"server": {
			"cwd": "apps/server",
			"command": "bun run dev",
			"health": { "type": "port", "port": 30206 },
			"dependsOn": [],
			"env": {
				"PORT": "30206",
				"OPENCODE_PORT": "4096",
				"OPENCODE_HOSTNAME": "127.0.0.1"
			}
		},
		"web": {
			"cwd": "apps/desktop",
			"command": "bun run dev:web",
			"health": { "type": "port", "port": 20883 },
			"dependsOn": ["server"],
			"env": {
				"PORT": "20883"
			}
		},
		"desktop": {
			"cwd": "apps/desktop",
			"command": "bun run dev:electron-local",
			"health": { "type": "port", "port": 1420 },
			"dependsOn": [],
			"env": {
				"OPENCODE_PORT": "4096"
			}
		},
		"desktop-wayland": {
			"cwd": "apps/desktop",
			"command": "bun run dev:electron-wayland-local",
			"health": { "type": "port", "port": 1420 },
			"dependsOn": [],
			"env": {
				"OPENCODE_PORT": "4096"
			}
		}
	}
}
